<Project Sdk="Atya.Build.Sdk">

  <PropertyGroup>
    <AssemblyName>Atya.Foundation.Results</AssemblyName>
    <PackageId>Atya.Foundation.Results</PackageId>
    <RootNamespace>Atya.Foundation.Results</RootNamespace>
    <IsPackable>true</IsPackable>
    <Authors>Arsen Asulyan</Authors>
    <Company>Atya</Company>
    <Copyright>Copyright (c) 2026 Arsen Asulyan</Copyright>
    <Description>Result and Error primitives for expected, recoverable outcomes in Atya libraries.</Description>
    <PackageTags>dotnet;atya;foundation;results;errors</PackageTags>
    <RepositoryUrl>https://github.com/AtyaLibraries/Results</RepositoryUrl>
    <PackageProjectUrl>$(RepositoryUrl)</PackageProjectUrl>
    <PackageValidationBaselineVersion>1.1.0</PackageValidationBaselineVersion>

    <!-- MinVer derives the version from git tags (e.g. tag `v1.2.3` -> 1.2.3). -->
    <MinVerTagPrefix>v</MinVerTagPrefix>
    <MinVerDefaultPreReleaseIdentifiers>alpha.0</MinVerDefaultPreReleaseIdentifiers>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
    <None Include="..\..\LICENSE" Pack="true" PackagePath="\" Visible="false" />
  </ItemGroup>

</Project>
